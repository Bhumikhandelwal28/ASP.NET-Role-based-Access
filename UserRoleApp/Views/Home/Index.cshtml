@{
    ViewData["Title"] = SharedLocalizer["1"].Value;
}

<div class="hero">
    <div class="hero-content">
        <h1>
            @SharedLocalizer["website_web"]
            <span class="brand-text">@SharedLocalizer["1"]</span>
        </h1>
        <p>@SharedLocalizer["jwt_web"]</p>
        <div class="hero-buttons">
            <a href="/Account/Login"    class="btn btn-primary">@SharedLocalizer["login"]</a>
            <a href="/Account/Register" class="btn btn-outline">@SharedLocalizer["register"]</a>
        </div>
    </div>
</div>
