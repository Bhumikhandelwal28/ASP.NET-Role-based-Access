@model UserRoleApp.Models.Users
@{ ViewData["Title"] = "Faculty Dashboard"; }

<div class="page-header">
    <div><h1>Faculty Dashboard</h1><p class="page-sub">Welcome back, @Model?.FullName</p></div>
    <a href="/Faculty/Students" class="btn btn-primary">View Students</a>
</div>

<div class="profile-card">
    <div class="profile-avatar faculty-avatar">👨‍🏫</div>
    <div class="profile-info">
        <h2>@Model?.FullName</h2>
        <p class="profile-email">@Model?.Email</p>
        <span class="badge badge-faculty">Faculty</span>
    </div>
    <div class="profile-details">
        <div class="detail-row">
            <span class="detail-label">Department</span>
            <span class="detail-value">@(Model?.Department ?? "Not specified")</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">Joined</span>
            <span class="detail-value">@Model?.CreatedAt.ToString("MMMM dd, yyyy")</span>
        </div>
    </div>
</div>
