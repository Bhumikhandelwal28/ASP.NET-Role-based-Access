@model EditUserViewModel
@{ ViewData["Title"] = "Edit Student"; }

<div class="page-header">
    <div><h1>Edit Student</h1><p class="page-sub">Update student information</p></div>
    <a href="/Faculty/Students" class="btn btn-outline">← Back</a>
</div>

<div class="form-card">
    <form asp-action="EditStudent" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="FullName">Full Name</label>
                <input asp-for="FullName" class="form-input" />
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>
            <div class="form-group">
                <label>Email <span class="optional">(read-only)</span></label>
                <input value="@Model.Email" class="form-input" readonly />
            </div>
            <div class="form-group">
                <label asp-for="Department">Department</label>
                <input asp-for="Department" class="form-input" />
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/Faculty/Students" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
