@model ChangePasswordViewModel
@{ ViewData["Title"] = "Change Password"; Layout = null; }

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Password – UserRole System</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="auth-page">
<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
           
            <h2>Reset Password</h2>
            <p>Enter your email and new password</p>
        </div>
        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" type="email" class="form-input" placeholder="your@email.com" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="NewPassword">New Password</label>
                <input asp-for="NewPassword" type="password" class="form-input" placeholder="Min. 6 characters" />
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="Repeat password" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-full">Update Password</button>
            <p class="auth-footer"><a href="/Account/Login">← Back to Login</a></p>
        </form>
    </div>
</div>
</body>
</html>
