@{
    ViewData["Title"] = SharedLocalizer["access_denied_title"].Value;
}

<div class="error-page">
    <div class="error-card">
        <h1 class="error-code">403</h1>
        <h2 class="error-title">@SharedLocalizer["access_denied_title"]</h2>
        <p class="error-message">@SharedLocalizer["access_denied_msg"]</p>
        <a href="javascript:history.back()" class="btn btn-outline">
            @SharedLocalizer["access_denied_back"]
        </a>
        <a href="/" class="btn btn-primary" style="margin-left:.5rem">
            @SharedLocalizer["error_back_home"]
        </a>
    </div>
</div>
