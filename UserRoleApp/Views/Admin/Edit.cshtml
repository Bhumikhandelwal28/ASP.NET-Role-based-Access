@model EditUserViewModel
@{ ViewData["Title"] = "Edit User"; }

<div class="page-header">
    <div><h1>Edit User</h1><p class="page-sub">Update user information</p></div>
    <a href="/Admin/Index" class="btn btn-outline">← Back</a>
</div>

<div class="form-card">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="FullName">Full Name</label>
                <input asp-for="FullName" class="form-input" />
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" type="email" class="form-input" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Department">Department</label>
                <input asp-for="Department" class="form-input" />
            </div>
            <div class="form-group">
                <label asp-for="Role">Role</label>
                <select asp-for="Role" class="form-input form-select">
                    <option value="Faculty">Faculty</option>
                    <option value="Student">Student</option>
                </select>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/Admin/Index" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
