@model List<(UserRoleApp.Models.Users user, IList<string> roles)>
@{ ViewData["Title"] = "Admin Dashboard"; }

<div class="page-header">
    <div>
        <h1>Admin Dashboard</h1>
        <p class="page-sub">Manage all users in the system</p>
    </div>
</div>

<div class="stats-row">
    <div class="stat-card">
        <div class="stat-num">@Model.Count</div>
        <div class="stat-label">Total Users</div>
    </div>
    <div class="stat-card">
        <div class="stat-num">@Model.Count(x => x.roles.Contains("Admin"))</div>
        <div class="stat-label">Admins</div>
    </div>
    <div class="stat-card">
        <div class="stat-num">@Model.Count(x => x.roles.Contains("Faculty"))</div>
        <div class="stat-label">Faculty</div>
    </div>
    <div class="stat-card">
        <div class="stat-num">@Model.Count(x => x.roles.Contains("Student"))</div>
        <div class="stat-label">Students</div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3>All Users</h3>
        <input type="text" id="searchInput" placeholder="Search users..." class="search-input" oninput="filterTable()" />
    </div>
    <div class="table-wrapper">
        <table class="data-table" id="userTable">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Department</th>
                    <th>Role</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (user, roles) in Model)
                {
                    var role = roles.FirstOrDefault() ?? "—";
                    <tr>
                        <td><strong>@user.FullName</strong></td>
                        <td>@user.Email</td>
                        <td>@(user.Department ?? "—")</td>
                        <td><span class="badge badge-@role.ToLower()">@role</span></td>
                        <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td class="actions">
                            <a href="/Admin/Edit/@user.Id" class="btn-sm btn-edit">Edit</a>
                            @if (role != "Admin")
                            {
                                <form asp-action="Delete" asp-controller="Admin" method="post" style="display:inline"
                                      onsubmit="return confirm('Delete @user.FullName?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn-sm btn-delete">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
function filterTable() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('#userTable tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
}
</script>
}
